# Automatic HTTPS for the tracker. Caddy fetches and renews a Let's Encrypt
# certificate for {$DOMAIN} on its own.
{$DOMAIN} {
	encode zstd gzip

	# Server-Sent Events: stream the /events endpoint without buffering.
	@sse path /events
	reverse_proxy @sse app:8000 {
		flush_interval -1
	}

	reverse_proxy app:8000
}
